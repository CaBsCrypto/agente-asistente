{
    "name": "agente-asistente",
    "version": "0.1.0",
    "private": true,
    "engines": {
        "node": ">=22.13.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "test": "tsx --test tests/*.test.ts",
        "x402:signing:doctor": "tsx --env-file=.env.local scripts/x402-signing-doctor.ts",
        "x402:replay:confirmed": "tsx scripts/x402-replay-proof.ts confirmed",
        "x402:replay:execute": "tsx scripts/x402-replay-proof.ts execute",
        "acceptance:doctor": "tsx scripts/acceptance.ts doctor",
        "acceptance:travala": "tsx scripts/acceptance.ts travala",
        "acceptance:authenticated": "tsx scripts/acceptance.ts authenticated",
        "acceptance:execute": "tsx scripts/acceptance.ts execute",
        "acceptance:unblck": "tsx --env-file=.env.production.local --env-file=.env.local scripts/unblck-acceptance.ts",
        "unblck:fix-check": "tsx --env-file=.env.local scripts/unblck-fix-check.ts",
        "acceptance:second-user:start": "tsx scripts/second-user-acceptance.ts start",
        "acceptance:second-user:fund-usdc": "tsx scripts/second-user-acceptance.ts fund-usdc",
        "acceptance:second-user:verify": "tsx scripts/second-user-acceptance.ts verify",
        "qa:local": "npm run lint && npm run test && npm run build",
        "qa:production": "npm run acceptance:doctor",
        "qa": "npm run qa:local && npm run qa:production",
        "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
        "db:generate": "drizzle-kit generate",
        "test:build": "npm run test && npm run build",
        "db:migrate": "drizzle-kit migrate",
        "build:sites": "vinext build",
        "bridge:doctor": "tsx scripts/browser-bridge-doctor.ts",
        "graph:extract": "graphify extract . --code-only",
        "graph:report": "graphify cluster-only .",
        "graph:update": "graphify update .",
        "graph:doctor": "graphify hook status",
        "graph:rebuild": "graphify extract . --code-only --force",
        "graph:mcp:smoke": "tsx scripts/graphify-mcp-smoke.ts",
        "langchain:smoke": "tsx --env-file=.env.local scripts/langchain-planner-smoke.ts"
    },
    "dependencies": {
        "@langchain/langgraph": "^1.4.8",
        "@langchain/openai": "^1.5.5",
        "@langchain/openrouter": "^0.4.5",
        "@modelcontextprotocol/sdk": "^1.26.0",
        "@neondatabase/serverless": "^1.1.0",
        "@openzeppelin/relayer-plugin-channels": "^0.20.0",
        "@privy-io/node": "0.26.0",
        "@privy-io/react-auth": "3.35.0",
        "@stellar/stellar-sdk": "^16.0.1",
        "@x402/core": "^2.18.0",
        "@x402/fetch": "^2.18.0",
        "@x402/stellar": "^2.18.0",
        "drizzle-orm": "0.45.2",
        "langchain": "^1.5.3",
        "mcp-handler": "^1.1.0",
        "next": "16.2.6",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-loading-skeleton": "3.5.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "1.37.1",
        "@tailwindcss/postcss": "4.2.1",
        "@types/node": "22.19.19",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "@vitejs/plugin-rsc": "0.5.26",
        "drizzle-kit": "0.31.10",
        "eslint": "9.39.4",
        "eslint-config-next": "16.2.6",
        "react-server-dom-webpack": "19.2.6",
        "tailwindcss": "4.2.1",
        "tsx": "^4.23.1",
        "typescript": "5.9.3",
        "vinext": "0.0.50",
        "vite": "8.0.13",
        "wrangler": "4.92.0"
    },
    "type": "module"
}
