{
  "manifest_version": 3,
  "name": "agent-assistant Browser Bridge",
  "version": "0.1.0",
  "description": "Connects explicitly allowed browser tabs to agent-assistant without exporting cookies or passwords.",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://agente-asistente.vercel.app/*",
    "http://localhost:3000/*",
    "https://www.unblck.cl/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://agente-asistente.vercel.app/*", "http://localhost:3000/*"],
      "js": ["agent-content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.unblck.cl/*"],
      "js": ["unblck-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "agent-assistant Browser Bridge"
  }
}
