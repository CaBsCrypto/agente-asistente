DATABASE_URL=

# Founder admin access. Generate a scrypt hash; never commit the password.
ADMIN_USERNAME=founder
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
# Optional comma-separated allowlist for ChatGPT/Sites authenticated users.
ADMIN_EMAILS=

# Founder-only Privy + Stellar Testnet lab. Both variables stay server-side.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Public identifier used by the Privy React SDK. Usually the same App ID.
NEXT_PUBLIC_PRIVY_APP_ID=
# Optional Privy app client for per-domain configuration.
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Dedicated Testnet-only distributor. Its public address is pinned in code.
# Never reuse this key on Mainnet or for user funds.
STELLAR_TESTNET_USDC_DISTRIBUTOR_SECRET=

# Optional temporary token for authenticated acceptance runs.
AGENT_ACCEPTANCE_PRIVY_TOKEN=
ACCEPT_TESTNET_MUTATIONS=

# 32 random bytes encoded as base64. Encrypts external OAuth tokens at rest.
CONNECTOR_ENCRYPTION_KEY=
# OpenZeppelin managed Stellar Channels. Testnet only: fee sponsorship and
# submission after the user has signed through Privy. Never expose this key.
OPENZEPPELIN_CHANNELS_TESTNET_API_KEY=

# Optional plan-only LangChain router. It may classify and propose actions but
# never signs or submits transactions. Keep the API key server-side.
AGENT_LANGCHAIN_ENABLED=false
AGENT_LANGCHAIN_PROVIDER=openrouter
AGENT_LANGCHAIN_MODEL=openrouter/free
OPENROUTER_API_KEY=
# Optional alternative provider. Set AGENT_LANGCHAIN_PROVIDER=openai to use it.
OPENAI_API_KEY=

# Soroswap server credential. Never expose this with a NEXT_PUBLIC_ prefix.
SOROSWAP_API_KEY=
